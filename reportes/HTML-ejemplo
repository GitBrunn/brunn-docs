<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Alfajores Vimar · Mayo 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet">
<style>
:root{
  --paper:#F1EBE5;--card:#FFFFFF;--ink:#1A1A1A;--ink-soft:#5A5A5A;--muted:#8B8B8B;
  --blue:#1F1F1F;--blue-dark:#0A0A0A;--blue-soft:#E8E1D8;
  --red:#D92D20;--amber:#FF721C;--amber-soft:#FFE7D6;--line:#E3DCD2;--accent2:#FF721C;
  --up:#3F9D6B;--down:#D92D20;--barlo:#C2B9AD;
  --disp:'Bricolage Grotesque',system-ui,sans-serif;--sans:'Archivo',system-ui,sans-serif;
  --shadow:0 1px 2px rgba(20,40,80,.04),0 8px 24px rgba(20,40,80,.06);
  --transition:all .22s cubic-bezier(.2,.7,.3,1);
}
:root[data-theme="dark"]{
  --paper:#232327;--card:#2C2C31;--ink:#F1EBE5;--ink-soft:#B1B1B1;--muted:#8B8B8B;
  --blue:#FF721C;--blue-dark:#F1EBE5;--blue-soft:rgba(255,114,28,.16);
  --red:#F0726A;--amber:#FF8A3D;--amber-soft:rgba(255,138,61,.18);--line:rgba(241,235,229,.12);--accent2:#F1EBE5;
  --up:#46C88A;--down:#F0726A;--barlo:#4A4A4F;--shadow:0 1px 2px rgba(0,0,0,.25),0 8px 24px rgba(0,0,0,.32);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--sans);color:var(--ink);background:radial-gradient(1000px 500px at 90% -5%,var(--blue-soft),transparent 55%),var(--paper);min-height:100vh;padding:28px 28px 64px;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s}
.wrap{max-width:1200px;margin:0 auto}
header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;border-bottom:2px solid var(--line);padding-bottom:20px;margin-bottom:22px}
.brand{display:flex;align-items:center;gap:14px}
.brand-logo{height:34px;width:auto;object-fit:contain;display:block}
.logo-dark{display:none}
:root[data-theme="dark"] .logo-light{display:none}
:root[data-theme="dark"] .logo-dark{display:block}
.brand-meta .client{font-family:var(--disp);font-size:17px;font-weight:700;color:var(--blue-dark);line-height:1.1;border-left:1.5px solid var(--line);padding-left:14px}
.head-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.sim-tag{display:inline-flex;align-items:center;gap:6px;font-size:10px;font-weight:700;color:var(--amber);background:var(--amber-soft);border:1px solid var(--amber-soft);border-radius:100px;padding:5px 11px}
.period-badge{display:inline-flex;align-items:center;gap:7px;font-size:11px;letter-spacing:.08em;font-weight:700;color:var(--blue-dark);border:1.5px solid var(--line);border-radius:100px;padding:7px 14px;background:var(--card)}
.period-badge .dot{width:7px;height:7px;border-radius:50%;background:var(--up)}
.icon-btn{font-family:var(--sans);font-size:11.5px;font-weight:700;color:var(--ink-soft);background:var(--card);border:1.5px solid var(--line);border-radius:100px;padding:8px 15px;cursor:pointer;transition:var(--transition)}
.icon-btn:hover{border-color:var(--blue);color:var(--blue)}
.theme-switch{display:inline-flex;align-items:center;gap:9px;background:var(--card);border:1.5px solid var(--line);border-radius:100px;padding:6px 13px;cursor:pointer;font-family:var(--sans);transition:var(--transition)}
.theme-switch:hover{border-color:var(--blue)}
.ts-text{font-size:11.5px;font-weight:700;color:var(--ink-soft);min-width:30px;text-align:left;letter-spacing:.02em}
.ts-track{width:34px;height:18px;border-radius:100px;background:var(--line);position:relative;transition:background .2s;flex-shrink:0}
.ts-knob{position:absolute;top:2px;left:2px;width:14px;height:14px;border-radius:50%;background:var(--blue);transition:transform .2s}
:root[data-theme="dark"] .ts-track{background:var(--blue-soft)}
:root[data-theme="dark"] .ts-knob{transform:translateX(16px)}
.main-tabs{display:flex;gap:6px;margin-bottom:22px}
.main-tab{font-family:var(--sans);font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft);background:var(--card);border:1.5px solid var(--line);border-radius:100px;padding:11px 28px;cursor:pointer;transition:var(--transition)}
.main-tab:hover{border-color:var(--blue);color:var(--blue)}
.main-tab.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.sub-tabs{display:flex;gap:20px;margin-bottom:22px;border-bottom:1.5px solid var(--line);overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.sub-tabs::-webkit-scrollbar{display:none}
.sub-tab{font-family:var(--disp);font-size:15px;font-weight:600;color:var(--muted);background:none;border:none;padding:0 0 12px;cursor:pointer;position:relative;white-space:nowrap;flex-shrink:0;transition:color .18s}
.sub-tab:hover{color:var(--ink-soft)}
.sub-tab.active{color:var(--blue)}
.sub-tab.active::after{content:"";position:absolute;bottom:-1.5px;left:0;width:100%;height:3px;background:var(--amber);border-radius:3px}
.ch-tabs{display:flex;gap:0;margin-bottom:24px;background:var(--card);border:1.5px solid var(--line);border-radius:14px;padding:4px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.ch-tabs::-webkit-scrollbar{display:none}
.ch-tab{font-family:var(--sans);font-size:12px;font-weight:700;color:var(--muted);background:transparent;border:none;border-radius:10px;padding:9px 18px;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:var(--transition)}
.ch-tab:hover{color:var(--ink)}
.ch-tab.active{background:var(--blue);color:#fff}
.panel{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:20px;box-shadow:var(--shadow)}
.panel h2{font-family:var(--disp);font-size:16px;font-weight:700;color:var(--blue-dark);margin-bottom:3px}
.ph-sub{font-size:11px;color:var(--muted);margin-bottom:14px}
.kpis{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:14px}
.kpi{background:var(--card);border:1px solid var(--line);border-radius:13px;padding:15px 14px 13px;position:relative;overflow:hidden;box-shadow:0 3px 12px rgba(20,40,80,.04)}
.kpi::before{content:"";position:absolute;top:0;left:0;width:100%;height:3px;background:var(--amber)}
.kpi .lbl{font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:8px}
.kpi .val{font-family:var(--disp);font-size:21px;font-weight:800;color:var(--blue-dark);line-height:1}
.kpi .sub{margin-top:7px;font-size:10px;color:var(--muted);font-weight:500}
.kpi .delta{margin-top:7px;font-size:10.5px;font-weight:700;display:flex;align-items:center;gap:4px}
.kpi .delta.up{color:var(--up)}.kpi .delta.down{color:var(--down)}
.kpi .delta span{color:var(--muted);font-weight:500;font-size:9px}
.consol-label{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--amber);font-weight:700;margin-bottom:10px}
.consol-panel{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:22px 26px;margin-bottom:22px;box-shadow:var(--shadow);display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap;position:relative;overflow:hidden}
.consol-panel::before{content:"";position:absolute;top:0;left:0;width:5px;height:100%;background:var(--amber)}
.consol-stats{display:grid;grid-template-columns:repeat(4,auto);gap:30px;flex:1;min-width:280px}
.cs-l{font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:6px}
.cs-v{font-family:var(--disp);font-size:25px;font-weight:800;color:var(--blue-dark);line-height:1}
.cs-s{font-size:10px;color:var(--muted);margin-top:5px;font-weight:500}
.consol-donut{display:flex;align-items:center;gap:14px}
.donut-leg{display:flex;flex-direction:column;gap:6px}
.donut-leg span{font-size:11px;color:var(--ink-soft);font-weight:600;display:flex;align-items:center;gap:6px;white-space:nowrap}
.donut-leg i{width:9px;height:9px;border-radius:2px;display:inline-block}
.snap-intro{font-size:11px;color:var(--muted);margin-bottom:14px;letter-spacing:.04em}
.snapshot{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:22px}
.snap-card{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:15px;cursor:pointer;transition:var(--transition);box-shadow:var(--shadow)}
.snap-card:hover{transform:translateY(-2px);border-color:var(--blue)}
.snap-card .ch-name{font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:var(--muted);margin-bottom:8px}
.snap-card .snap-val{font-family:var(--disp);font-size:20px;font-weight:800;color:var(--blue-dark);line-height:1}
.snap-card .snap-label{font-size:10px;color:var(--muted);margin-top:5px;font-weight:500}
.grid-2{display:grid;grid-template-columns:1.9fr 1fr;gap:16px;margin-top:16px}
.mt-row{display:flex;gap:5px;margin-bottom:12px;flex-wrap:wrap}
.mt{font-size:10px;font-weight:700;color:var(--ink-soft);background:var(--card);border:1.5px solid var(--line);border-radius:7px;padding:5px 10px;cursor:pointer;transition:var(--transition)}
.mt:hover{border-color:var(--blue);color:var(--blue)}
.mt.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.chart-stats{display:flex;gap:18px;margin-bottom:12px;flex-wrap:wrap;font-size:11px;color:var(--muted);font-weight:500}
.chart-stats b{color:var(--blue-dark);font-family:var(--disp);font-weight:700;font-size:14px;display:block;margin-top:2px}
.chart-box{position:relative}
svg.chart{display:block;width:100%;height:auto;overflow:visible}
.tip{position:absolute;pointer-events:none;opacity:0;transform:translate(-50%,-115%);background:var(--blue-dark);color:var(--card);border-radius:8px;padding:5px 10px;font-size:10.5px;white-space:nowrap;transition:opacity .12s;z-index:9}
.tip b{color:var(--amber)}
.rank-row{margin-bottom:13px}.rank-row:last-child{margin-bottom:0}
.rank-top{display:flex;justify-content:space-between;align-items:baseline;font-size:12px;margin-bottom:5px}
.rank-top .nm{color:var(--ink);font-weight:600;display:flex;align-items:center;gap:7px}
.rank-top .nm .ix{color:var(--amber);font-family:var(--disp);font-weight:800;font-size:13px}
.rank-top .mv{color:var(--muted);font-size:10.5px}.rank-top .mv b{color:var(--blue-dark)}
.bar{height:7px;border-radius:6px;background:var(--blue-soft);overflow:hidden}
.bar i{display:block;height:100%;border-radius:6px;background:linear-gradient(90deg,var(--barlo),var(--blue));transition:width .6s cubic-bezier(.2,.7,.3,1)}
.quick{background:var(--blue-soft);border:1px solid var(--line);border-left:4px solid var(--blue);border-radius:10px;padding:11px 15px;margin-top:14px}
.quick .qt{font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--blue);font-weight:700;margin-bottom:6px}
.quick ul{list-style:none;display:flex;flex-direction:column;gap:5px}
.quick li{font-size:12px;line-height:1.45;color:var(--ink);padding-left:13px;position:relative}
.quick li::before{content:"\203A";position:absolute;left:0;color:var(--amber);font-weight:800}
.quick li b{color:var(--blue-dark)}
.exec-hero{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:30px 32px;margin-bottom:18px;position:relative;overflow:hidden;box-shadow:var(--shadow)}
.exec-hero::before{content:"";position:absolute;top:0;left:0;width:5px;height:100%;background:var(--blue)}
.exec-hero .etag{font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--red);font-weight:700;margin-bottom:12px}
.exec-hero .ehead{font-family:var(--disp);font-size:26px;line-height:1.18;font-weight:600;color:var(--ink);letter-spacing:-.01em;max-width:780px}
.exec-hero .ehead b{color:var(--blue)}
.exec-body{display:grid;grid-template-columns:1.6fr 1fr;gap:16px;margin-top:16px}
.narrative p{font-size:13.5px;line-height:1.66;color:var(--ink-soft);margin-bottom:12px}
.narrative p b{color:var(--blue-dark);font-weight:700}
.meaning{border-left:3px solid var(--amber);padding:2px 0 2px 14px;color:var(--ink);font-style:italic;font-family:var(--disp);font-size:14px;font-weight:500;line-height:1.55}
.highlights{display:flex;flex-direction:column;gap:10px}
.hl{background:var(--blue-soft);border:1px solid var(--line);border-radius:12px;padding:13px 16px}
.hl .v{font-family:var(--disp);font-size:24px;font-weight:800;color:var(--blue);line-height:1}
.hl .l{font-size:11px;color:var(--ink-soft);margin-top:5px;line-height:1.4;font-weight:500}
.pillar{background:var(--card);border:1px solid var(--line);border-radius:15px;padding:20px 22px;margin-bottom:12px;display:grid;grid-template-columns:44px 1fr;gap:14px;align-items:start;box-shadow:0 4px 16px rgba(20,40,80,.04)}
.pillar .badge{width:44px;height:44px;border-radius:12px;background:var(--amber-soft);color:var(--amber);display:grid;place-items:center;font-family:var(--disp);font-size:18px;font-weight:800;flex-shrink:0}
.pillar h3{font-family:var(--disp);font-size:16px;font-weight:700;color:var(--blue-dark);margin-bottom:6px}
.pillar p{font-size:13px;line-height:1.6;color:var(--ink-soft)}
.pillar p b{color:var(--ink)}
.pillar .move{margin-top:8px;font-size:11.5px;color:var(--blue)}
.pillar .move b{color:var(--red)}
footer{margin-top:30px;padding-top:16px;border-top:2px solid var(--line);display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;font-size:10.5px;color:var(--muted);font-weight:500}
footer b{color:var(--blue)}
.fade{animation:fade .4s ease both}@keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
[data-mv]{display:none}[data-mv].show{display:block}
[data-sv]{display:none}[data-sv].show{display:block}
[data-cv]{display:none}[data-cv].show{display:block}
@media(max-width:900px){.kpis,.snapshot{grid-template-columns:repeat(3,1fr)}.grid-2,.exec-body{grid-template-columns:1fr}.consol-stats{grid-template-columns:repeat(2,1fr);gap:18px}}
@media(max-width:600px){
  body{padding:14px 14px 48px}
  header{flex-direction:column;align-items:flex-start;gap:12px}
  .main-tab{font-size:11.5px;padding:9px 18px}
  .kpis,.snapshot{grid-template-columns:repeat(2,1fr);gap:10px}
  .kpi .val,.snap-card .snap-val{font-size:19px}
  .exec-hero{padding:18px 16px}.exec-hero .ehead{font-size:19px}
  .panel{padding:14px}.brand-logo{height:28px}
  .consol-panel{padding:18px}.cs-v{font-size:20px}
  footer{flex-direction:column;gap:4px}
}
@media print{
  body{padding:0;background:#fff;color:#000}
  .main-tabs,.sub-tabs,.ch-tabs,.theme-switch,#printBtn{display:none !important}
  [data-mv],[data-sv],[data-cv]{display:block !important}
  .panel,.exec-hero,.pillar,.consol-panel,.snap-card,.kpi{box-shadow:none !important;break-inside:avoid}
  [data-cv]{page-break-before:always;padding-top:8px}
  [data-cv]:first-child{page-break-before:auto}
  [data-sv="next"]{page-break-before:always}
  .tip{display:none !important}
  header{border-bottom:2px solid #ccc}
}
</style>
</head>
<body>
<div class="wrap">
<header>
