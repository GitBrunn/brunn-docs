<script>/* BRUNN Dashboard Engine — render engine (FROZEN). Data-driven, channel-agnostic. */
var DATA = window.__BRUNN_DATA__;

/* ---- locale / formatters ---- */
var LOC = (DATA.meta && DATA.meta.locale) || 'es-AR';
var CUR = (DATA.meta && DATA.meta.currency) || '$';
var NF   = function(n){ return Math.round(n).toLocaleString(LOC); };
var ARS  = function(n){ return CUR + Math.round(n).toLocaleString(LOC); };
var PLUS = function(n){ return '+' + NF(n); };
var MINUS= function(n){ return '-' + NF(Math.abs(n)); };
var D1   = function(v){ return (typeof v==='number') ? v.toLocaleString(LOC,{minimumFractionDigits:1,maximumFractionDigits:1}) : (''+v); };
var PCT  = function(v){ return D1(v) + '%'; };
var STR  = function(v){ return '' + v; };
var SHORT= function(n){ n=Math.round(n); if(n>=1000000) return (n/1000000).toFixed(n>=10000000?0:1).replace('.0','').replace('.',',')+'M'; if(n>=1000) return Math.round(n/1000)+'K'; return n.toString(); };
var FMT  = { ars:ARS, int:NF, plus:PLUS, minus:MINUS, dec:D1, pct:PCT, str:STR, short:SHORT };
function fmt(key,v){ return (FMT[key]||STR)(v); }

/* ---- i18n labels ---- */
var LABELS = {
  es:{ resumen:'Resumen', metricas:'Métricas', exec:'Resumen Ejecutivo', next:'Próximos Pasos',
       totalCanal:'Total del Canal', lectura:'Lectura rápida',
       snapIntro:'Snapshot del mes · tocá un canal para ir directo a sus métricas',
       sim:'★ Data simulada', light:'Light', dark:'Dark', accion:'Acción Sugerida',
       negocio:'Resultado del negocio', footer:'BRUNN Dashboard Engine — 2026',
       dia:'Día', total:'Total', peak:'Pico', avgday:'Promedio/día' },
  en:{ resumen:'Overview', metricas:'Metrics', exec:'Executive Summary', next:'Next Steps',
       totalCanal:'Channel Total', lectura:'Quick read',
       snapIntro:'Monthly snapshot · tap a channel to jump to its metrics',
       sim:'★ Simulated data', light:'Light', dark:'Dark', accion:'Suggested Action',
       negocio:'Business result', footer:'BRUNN Dashboard Engine — 2026',
       dia:'Day', total:'Total', peak:'Peak', avgday:'Avg/day' }
};
var L = LABELS[(DATA.meta && DATA.meta.lang) || 'es'] || LABELS.es;

/* ---- header / static labels ---- */
function txt(id,v){ var e=document.getElementById(id); if(e) e.textContent=v; }
txt('clientName', DATA.meta.client);
txt('periodName', DATA.meta.period_label);
txt('tabResumen', L.resumen); txt('tabMetricas', L.metricas);
txt('subExec', L.exec); txt('subNext', L.next);
txt('snapIntro', L.snapIntro); txt('footerTxt', L.footer); txt('tsText', L.light);
if(DATA.meta.sim){ var st=document.getElementById('simTag'); if(st){ st.style.display=''; st.textContent=L.sim; } }

/* ---- theme toggle ---- */
document.getElementById('themeToggle').addEventListener('click', function(){
  var dark = document.documentElement.getAttribute('data-theme')==='dark';
  document.documentElement.setAttribute('data-theme', dark?'light':'dark');
  document.getElementById('tsText').textContent = dark?L.light:L.dark;
});

/* ---- chart stats ---- */
function chartStats(elId,vals,fmtKey){
  var el=document.getElementById(elId); if(!el) return;
  var total=vals.reduce(function(a,b){return a+b;},0), max=Math.max.apply(null,vals), avg=total/vals.length;
  el.innerHTML='<span>'+L.total+'<b>'+fmt(fmtKey,total)+'</b></span><span>'+L.peak+'<b>'+fmt(fmtKey,max)+'</b></span><span>'+L.avgday+'<b>'+fmt(fmtKey,avg)+'</b></span>';
}

/* ---- line chart (SVG, hand-rolled) ---- */
function drawChart(svgId,tipId,vals,fmtKey){
  var svg=document.getElementById(svgId); if(!svg) return;
  var vb=svg.getAttribute('viewBox').split(' '), W=+vb[2], H=+vb[3];
  var padL=46,padR=14,padT=20,padB=22, pw=W-padL-padR, ph=H-padT-padB;
  var max=Math.max.apply(null,vals)*1.12||1, min=0;
  var x=function(i){return padL+i*(pw/(vals.length-1));}, y=function(v){return padT+ph-((v-min)/(max-min))*ph;};
  var grid='',yl='';
  for(var g=0;g<=3;g++){ var gy=padT+ph*g/3, val=max*(1-g/3);
    grid+='<line x1="'+padL+'" y1="'+gy.toFixed(1)+'" x2="'+(W-padR)+'" y2="'+gy.toFixed(1)+'" stroke="var(--line)" stroke-width="1"/>';
    yl+='<text x="'+(padL-7)+'" y="'+(gy+3).toFixed(1)+'" text-anchor="end" font-size="9" fill="var(--muted)" font-family="Archivo,sans-serif">'+SHORT(val)+'</text>'; }
  var xl='', step=Math.max(1,Math.ceil(vals.length/5));
  for(var i=0;i<vals.length;i+=step){ xl+='<text x="'+x(i).toFixed(1)+'" y="'+(H-6)+'" text-anchor="middle" font-size="9" fill="var(--muted)" font-family="Archivo,sans-serif">'+(i+1)+'</text>'; }
  var ln=''; vals.forEach(function(v,i){ ln+=(i?'L':'M')+x(i).toFixed(1)+' '+y(v).toFixed(1)+' '; });
  var base=(padT+ph).toFixed(1);
  var area='M'+x(0).toFixed(1)+' '+base+' '+vals.map(function(v,i){return 'L'+x(i).toFixed(1)+' '+y(v).toFixed(1)+' ';}).join('')+'L'+x(vals.length-1).toFixed(1)+' '+base+' Z';
  var dots=''; vals.forEach(function(v,i){ dots+='<circle cx="'+x(i).toFixed(1)+'" cy="'+y(v).toFixed(1)+'" r="14" fill="transparent" data-i="'+i+'" data-v="'+v+'" style="cursor:pointer"/><circle cx="'+x(i).toFixed(1)+'" cy="'+y(v).toFixed(1)+'" r="2.2" fill="var(--blue)" pointer-events="none"/>'; });
  var pk=vals.indexOf(Math.max.apply(null,vals));
  var peak='<text x="'+x(pk).toFixed(1)+'" y="'+(y(vals[pk])-7).toFixed(1)+'" text-anchor="middle" font-size="9.5" font-weight="700" fill="var(--blue-dark)" font-family="Archivo,sans-serif">'+fmt(fmtKey,vals[pk])+'</text>';
  svg.innerHTML=grid+yl+xl+'<path d="'+area+'" fill="var(--blue-soft)" opacity=".6"/><path d="'+ln+'" fill="none" stroke="var(--blue)" stroke-width="2.2" stroke-linejoin="round"/>'+dots+peak;
  var tip=document.getElementById(tipId), box=svg.parentElement;
  svg.querySelectorAll('circle[data-i]').forEach(function(c){
    var show=function(){ var v=+c.dataset.v, i=+c.dataset.i; tip.innerHTML=L.dia+' '+(i+1)+' · <b>'+fmt(fmtKey,v)+'</b>'; var r=c.getBoundingClientRect(), br=box.getBoundingClientRect(); tip.style.left=(r.left-br.left+r.width/2)+'px'; tip.style.top=(r.top-br.top)+'px'; tip.style.opacity=1; };
    c.addEventListener('mouseenter',show);
    c.addEventListener('touchstart',function(e){ e.preventDefault(); show(); },{passive:false});
    c.addEventListener('mouseleave',function(){ tip.style.opacity=0; });
    c.addEventListener('touchend',function(){ setTimeout(function(){ tip.style.opacity=0; },1400); });
  });
}

/* ---- KPIs (data-driven; items = [{label,value,prev,fmt,inverse,fallback}]) ---- */
function renderKPIs(elId,items){
  var el=document.getElementById(elId); if(!el) return;
  el.innerHTML=items.map(function(it){
    var valStr=fmt(it.fmt,it.value), sub;
    if(it.prev==null || typeof it.value!=='number'){ sub='<div class="sub">'+(it.fallback||'')+'</div>'; }
    else{ var d=it.prev!==0?((it.value-it.prev)/it.prev*100):0; var up=d>=0; var good=it.inverse?!up:up; var arrow=up?'\u25B2':'\u25BC';
      sub='<div class="delta '+(good?'up':'down')+'">'+arrow+' '+Math.abs(d).toLocaleString(LOC,{minimumFractionDigits:1,maximumFractionDigits:1})+'% <span>'+(DATA.meta.compare_label||'')+'</span></div>'; }
    return '<div class="kpi fade"><div class="lbl">'+it.label+'</div><div class="val">'+valStr+'</div>'+sub+'</div>';
  }).join('');
}
function renderQuick(elId,bullets){ var el=document.getElementById(elId); if(!el) return; el.innerHTML=(bullets||[]).map(function(b){return '<li>'+b+'</li>';}).join(''); }

/* ---- Rankings (data-driven; items=[name,barValue,...], cols=[{idx,fmt,prefix,suffix,bold}]) ---- */
function renderRank(elId,items,cols){
  var el=document.getElementById(elId); if(!el) return;
  var mx=Math.max.apply(null,items.map(function(x){return x[1];}));
  el.innerHTML=items.map(function(it,i){
    var meta=cols.map(function(c){ var v=fmt(c.fmt,it[c.idx]); var s=(c.prefix||'')+(c.bold?'<b>'+v+'</b>':v)+(c.suffix||''); return s; }).join(' · ');
    return '<div class="rank-row"><div class="rank-top"><span class="nm"><span class="ix">'+(i+1)+'</span>'+it[0]+'</span><span class="mv">'+meta+'</span></div><div class="bar"><i style="width:'+(it[1]/mx*100)+'%"></i></div></div>';
  }).join('');
}

/* ---- Donut ---- */
function donut(segs){
  var total=segs.reduce(function(a,s){return a+s.v;},0); var R=40,r=25,cx=48,cy=48; var a0=-Math.PI/2,p='';
  segs.forEach(function(s){ var f=s.v/total, a1=a0+f*2*Math.PI;
    var x0=cx+R*Math.cos(a0),y0=cy+R*Math.sin(a0),x1=cx+R*Math.cos(a1),y1=cy+R*Math.sin(a1);
    var xi1=cx+r*Math.cos(a1),yi1=cy+r*Math.sin(a1),xi0=cx+r*Math.cos(a0),yi0=cy+r*Math.sin(a0);
    var lg=f>0.5?1:0;
    p+='<path d="M'+x0.toFixed(2)+' '+y0.toFixed(2)+' A'+R+' '+R+' 0 '+lg+' 1 '+x1.toFixed(2)+' '+y1.toFixed(2)+' L'+xi1.toFixed(2)+' '+yi1.toFixed(2)+' A'+r+' '+r+' 0 '+lg+' 0 '+xi0.toFixed(2)+' '+yi0.toFixed(2)+' Z" fill="'+s.c+'"/>';
    a0=a1; });
  return '<svg viewBox="0 0 96 96" width="88" height="88">'+p+'</svg>';
}

/* ---- Consolidated band (optional) ---- */
(function(){
  var c=DATA.consolidated, el=document.getElementById('consolidated'); if(!el) return;
  if(!c || !c.show){ el.innerHTML=''; return; }
  var stats=c.stats.map(function(s){ return '<div><div class="cs-l">'+s.label+'</div><div class="cs-v">'+fmt(s.fmt,s.value)+'</div><div class="cs-s">'+(s.sub||'')+'</div></div>'; }).join('');
  var dhtml='';
  if(c.donut && c.donut.segments && c.donut.segments.length){
    var cols=['var(--blue)','var(--accent2)','var(--muted)','var(--barlo)'];
    var segs=c.donut.segments.map(function(s,i){ return {v:s.value,c:cols[i%cols.length]}; });
    var tot=segs.reduce(function(a,s){return a+s.v;},0);
    var leg=c.donut.segments.map(function(s,i){ return '<span><i style="background:'+cols[i%cols.length]+'"></i>'+s.label+' '+Math.round(s.value/tot*100)+'%</span>'; }).join('');
    dhtml='<div class="consol-donut">'+donut(segs)+'<div class="donut-leg">'+leg+'</div></div>';
  }
  el.innerHTML='<div class="consol-label">'+(c.label||L.negocio)+'</div><div class="consol-panel"><div class="consol-stats">'+stats+'</div>'+dhtml+'</div>';
})();

/* ---- Snapshot ---- */
(function(){
  var el=document.getElementById('snapshot'); if(!el) return;
  el.innerHTML=(DATA.snapshot||[]).map(function(s){ return '<div class="snap-card" onclick="goChannel(\''+s.channel+'\')"><div class="ch-name">'+s.name+'</div><div class="snap-val">'+fmt(s.fmt,s.value)+'</div><div class="snap-label">'+s.label+'</div></div>'; }).join('');
})();

/* ---- Executive summary ---- */
(function(){
  var e=DATA.exec; if(!e) return;
  txt('execTag', e.etag);
  document.getElementById('execHead').innerHTML=e.headline;
  document.getElementById('execNarr').innerHTML=(e.narrative||[]).map(function(p){ return '<p'+(p.meaning?' class="meaning"':'')+'>'+p.text+'</p>'; }).join('');
  document.getElementById('execHl').innerHTML=(e.highlights||[]).map(function(h){ return '<div class="hl"><div class="v">'+h.value+'</div><div class="l">'+h.label+'</div></div>'; }).join('');
})();

/* ---- Next steps (pillars) ---- */
(function(){
  var el=document.getElementById('pasos'); if(!el) return;
  el.innerHTML=(DATA.pasos||[]).map(function(p,i){ return '<div class="pillar"><div class="badge">'+(i+1)+'</div><div><h3>'+p.title+'</h3><p>'+p.body+'</p><div class="move"><b>'+L.accion+':</b> '+p.action+'</div></div></div>'; }).join('');
})();

/* ---- Channels: build tabs + panels, then fill ---- */
(function(){
  var tabs='', panels='';
  DATA.channels.forEach(function(ch,idx){
    tabs+='<button class="ch-tab'+(idx===0?' active':'')+'" data-ch="'+ch.id+'">'+ch.title+'</button>';
    var sub=ch.subtitle || (ch.title+' · '+DATA.meta.period_label);
    var rk=ch.rankings||[];
    var p='<div data-cv="'+ch.id+'"'+(idx===0?' class="show"':'')+'>';
    p+='<div class="panel" style="margin-bottom:16px"><h2>'+L.totalCanal+'</h2><div class="ph-sub">'+sub+'</div><div class="kpis" id="kpi-'+ch.id+'"></div><div class="quick"><div class="qt">'+L.lectura+'</div><ul id="qr-'+ch.id+'"></ul></div></div>';
    var chartHtml='';
    if(ch.chart){
      var toggle='';
      if(ch.chart.series.length>1){ toggle='<div class="mt-row" id="mt-'+ch.id+'">'+ch.chart.series.map(function(s,si){return '<button class="mt'+(si===0?' active':'')+'" data-m="'+si+'">'+s.label+'</button>';}).join('')+'</div>'; }
      chartHtml='<div class="panel"><h2>'+ch.chart.title+'</h2><div class="ph-sub">'+(ch.chart.subtitle||'')+'</div>'+toggle+'<div class="chart-stats" id="stats-'+ch.id+'"></div><div class="chart-box"><svg class="chart" id="chart-'+ch.id+'" viewBox="0 0 720 260"></svg><div class="tip" id="tip-'+ch.id+'"></div></div></div>';
    }
    var rank0='';
    if(rk[0]){ rank0='<div class="panel"><h2>'+rk[0].title+'</h2><div class="ph-sub">'+(rk[0].subtitle||'')+'</div><div id="rank-'+ch.id+'-0"'+(rk[0].grid2?' style="display:grid;grid-template-columns:1fr 1fr;gap:8px 20px"':'')+'></div></div>'; }
    if(chartHtml||rank0){ p+='<div class="grid-2">'+chartHtml+rank0+'</div>'; }
    for(var j=1;j<rk.length;j++){ p+='<div class="panel" style="margin-top:16px"><h2>'+rk[j].title+'</h2><div class="ph-sub">'+(rk[j].subtitle||'')+'</div><div id="rank-'+ch.id+'-'+j+'"'+(rk[j].grid2?' style="display:grid;grid-template-columns:1fr 1fr;gap:8px 20px"':'')+'></div></div>'; }
    p+='</div>';
    panels+=p;
  });
  document.getElementById('chtabs').innerHTML=tabs;
  document.getElementById('chpanels').innerHTML=panels;

  DATA.channels.forEach(function(ch){
    renderKPIs('kpi-'+ch.id, ch.kpis);
    renderQuick('qr-'+ch.id, ch.quick);
    if(ch.chart){
      var sidx=0;
      var draw=function(){ var s=ch.chart.series[sidx]; chartStats('stats-'+ch.id,s.values,s.fmt); drawChart('chart-'+ch.id,'tip-'+ch.id,s.values,s.fmt); };
      draw();
      if(ch.chart.series.length>1){
        document.getElementById('mt-'+ch.id).addEventListener('click', function(e){
          if(!e.target.classList.contains('mt')) return;
          this.querySelectorAll('.mt').forEach(function(b){ b.classList.remove('active'); });
          e.target.classList.add('active'); sidx=+e.target.dataset.m; draw();
        });
      }
    }
    (ch.rankings||[]).forEach(function(rkk,j){ renderRank('rank-'+ch.id+'-'+j, rkk.items, rkk.cols); });
  });
})();

